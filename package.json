{
  "name": "agentready",
  "version": "0.1.0",
  "description": "Preflight security scanner for AI coding agent access to software projects.",
  "type": "module",
  "bin": {
    "agentready": "./bin/agentready.js"
  },
  "files": [
    "bin/",
    "src/",
    "docs/",
    "schema/",
    "AGENTS.md",
    ".agentignore",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "scan": "node ./bin/agentready.js scan",
    "scan:ci": "node ./bin/agentready.js scan . --ci",
    "doctor": "node ./bin/agentready.js doctor",
    "rules": "node ./bin/agentready.js list-rules",
    "config:validate": "node ./bin/agentready.js config validate .",
    "pack:dry-run": "npm pack --dry-run",
    "test": "node --test"
  },
  "keywords": [
    "ai-agent",
    "mcp",
    "security",
    "claude",
    "codex",
    "cli"
  ],
  "homepage": "https://github.com/wangjiehu/agentready#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangjiehu/agentready.git"
  },
  "bugs": {
    "url": "https://github.com/wangjiehu/agentready/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
